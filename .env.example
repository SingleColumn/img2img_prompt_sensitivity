# Copy this file to .env at the repo root and fill in your keys.
# Keys may also be set directly in your machine environment instead of using .env.
# Nothing here is required for mock-mode runs.

# Required for prompt generation, similarity scoring, and the OpenAI image model.
OPENAI_API_KEY=

# Required for the FAL-hosted image models.
FAL_KEY=

# Optional overrides (defaults shown). Leave unset to use the defaults.
# PROMPT_LLM_MODEL=gpt-5.5
# PROMPT_EMBEDDING_MODEL=text-embedding-3-large
